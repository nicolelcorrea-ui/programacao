# hora do programa
peso_queijo = 50 #gramas
peso_presunto = 50 #gramas
peso_burguer = 100 #gramas

quantidade_sanduiche = int("digite a quantidade de sanduiches :"))

peso_queijo_total = quantidade_sanduiche * (peso_queijo * 2)
peso_presunto_total = quantidade_sanduiche * peso_presunto * 2
peso_burguer_total = quantidade_sanduiche * peso_burguer * 2

# converter quilos
peso_queijo_totalkg = peso_queijo_total / 1000
peso_presunto_totalkg = peso_presunto_total / 1000
peso_burguer_totalkg = peso_burguer_total / 1000

print (" peso total queijo: {peso_queijo_totalkg} kg")
print (" peso total presunto: {peso_presunto_totalkg} kg")
print (" peso total burguer: {peso_burguer_totalkg} kg")